<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Monthly / Yearly toggle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/btnMonthly"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Monthly"
                android:backgroundTint="@color/purple_700"
                android:textColor="@android:color/white"
                android:layout_marginEnd="6dp" />

            <Button
                android:id="@+id/btnYearly"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Yearly"
                android:backgroundTint="#E0E0E0"
                android:textColor="#212121"
                android:layout_marginStart="6dp" />

        </LinearLayout>

        <!-- Period picker (list of months or years found in the data) -->
        <Spinner
            android:id="@+id/spinnerPeriod"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp" />

        <!-- Summary card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/purple_700"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:id="@+id/tvPeriodLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="July 2026"
                    android:textColor="#EDE7F6"
                    android:textSize="13sp"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/tvPeriodTotal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="₹0.00"
                    android:textColor="@android:color/white"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Budget progress -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="1dp"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Budget"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <Button
                        android:id="@+id/btnSetBudget"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:minWidth="0dp"
                        android:paddingHorizontal="14dp"
                        android:text="Set budget"
                        android:textSize="12sp"
                        android:textAllCaps="false"
                        android:backgroundTint="#EDE7F6"
                        android:textColor="@color/purple_700" />

                </LinearLayout>

                <TextView
                    android:id="@+id/tvBudgetSummary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No budget set for this period."
                    android:textSize="13sp"
                    android:textColor="#757575"
                    android:layout_marginTop="8dp" />

                <ProgressBar
                    android:id="@+id/progressBudget"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="10dp"
                    android:layout_marginTop="10dp"
                    android:max="100"
                    android:progress="0"
                    android:progressTint="@color/purple_700"
                    android:visibility="gone" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Category breakdown -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Spending by category"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <com.github.mikephil.charting.charts.PieChart
            android:id="@+id/pieChart"
            android:layout_width="match_parent"
            android:layout_height="260dp"
            android:layout_marginBottom="24dp" />

        <TextView
            android:id="@+id/tvNoData"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No expenses for this period yet."
            android:textColor="#9E9E9E"
            android:gravity="center"
            android:visibility="gone"
            android:layout_marginBottom="24dp" />

        <!-- Trend: day-by-day for a month, or month-by-month for a year -->
        <TextView
            android:id="@+id/tvTrendLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Daily trend"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <com.github.mikephil.charting.charts.BarChart
            android:id="@+id/barChart"
            android:layout_width="match_parent"
            android:layout_height="240dp"
            android:layout_marginBottom="16dp" />

    </LinearLayout>

</ScrollView>
